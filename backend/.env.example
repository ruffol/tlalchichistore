# Database (set DATABASE_URL for PostgreSQL, or leave empty for SQLite)
# DATABASE_URL=postgres://user:password@host:5432/market?sslmode=disable
DATABASE_PATH=./data/market.db

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# Server
PORT=8080
ENVIO_USD=5
APP_URL=http://localhost:8080

# Frontend (for Go serving Next.js build)
FRONTEND_DIR=./frontend/dist
